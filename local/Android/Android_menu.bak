if source ${HOME}/.gancm/local/Android/Android_function ; then
	echo -e "${SUSSEC}加载安卓功能成功"
else	
	echo -e "${WORRY}加载安卓功能失败"
fi
case $1 in
install)
     case $2 in
     proot)
     	install_proot
     ;;
     *)
          echo -e "
          ${WORRY}请输入完整命令
          install proot
          "
     ;;
	esac

;;
start)
     case $2 in
     proot)
     	start_proot
     ;;
     *)
          echo -e "
          ${WORRY}请输入完整命令
          start proot
          "
     ;;
	esac

;;
*)
     Android_menu=$(
     	whiptail --title "选择功能" --menu "termux按自己需求来" 15 60 4 \
     	"1" "管理proot容器" \
     	"2" "待添加" \
     	"0" "退出" 3>&1 1>&2 2>&3
     )
     case $Android_menu in
     1)
     	self_install proot pkg
     	#必要安装 proot功能实现的基础
     	open_proot=$(
     		whiptail --title "选择功能" --menu "termux按自己需求来" 15 60 4 \
     		"1" "安装proot容器" \
     		"2" "启动proot容器" \
     		"0" "退出" 3>&1 1>&2 2>&3
     	)
     	case $open_proot in
     	1)
     		install_proot
     			;;
     	2)
     		start_proot
     		;;
     	*)
     		echo -e "${RED}quit${RES}"
     		;;
     	esac
     	;;
     
     *)
     	echo -e "待添加_Android_menu"
     	;;
     esac
;;
esac